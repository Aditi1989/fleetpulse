# PostgreSQL (optional — without DATABASE_URL the app uses in-memory store)
# DATABASE_URL=postgres://user:pass@localhost:5432/fleetpulse

# Euler Shepherd API (server-side only — never expose to the browser)
SHEPHERD_BASE_URL=https://shepherd.eulermotors.com
SHEPHERD_BASIC_USER=
SHEPHERD_BASIC_PASSWORD=
# Or pre-encoded Basic value (alternative to USER/PASSWORD):
# SHEPHERD_BASIC_AUTH=

# Optional paths (defaults shown — confirmed for Euler Shepherd)
# SHEPHERD_LOGIN_PATH=/api/v3/user-login
# Euler Shepherd vehicles: /api/v1/vehicle-groups/list (returns groups with nested vehicles)
# SHEPHERD_VEHICLES_PATH=/api/v1/vehicle-groups/list

# Token Authorization header prefix. Euler sends raw JWT with NO "Bearer " prefix.
# Set to "Bearer " for standard RFC-6750 APIs.
# SHEPHERD_TOKEN_PREFIX=

# After login: use Bearer token (default) or Basic for every request
# SHEPHERD_AUTH_MODE=bearer

# If login JSON nests the token, set a dot path e.g. data.accessToken
# SHEPHERD_TOKEN_JSON_PATH=

# Optional: default map position when API omits GPS (India default below)
# SHEPHERD_DEFAULT_LAT=28.6139
# SHEPHERD_DEFAULT_LNG=77.209

# Optional: protect POST /api/shepherd/sync
# SHEPHERD_SYNC_SECRET=

# Optional: auto-sync interval in ms (>=5000). Requires custom server (npm run dev).
# SHEPHERD_SYNC_INTERVAL_MS=60000

# Throttle Shepherd sync when the dashboard calls GET /api/devices (default 25000 ms).
# Use 0 to sync on every devices request. Use -1 to disable sync-on-fetch (boot + manual POST only).
# SHEPHERD_DEVICES_FETCH_SYNC_MS=25000

# SHEPHERD_REQUEST_TIMEOUT_MS=30000
